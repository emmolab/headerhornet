# HeaderHornet Docker Compose example environment
# Copy to .env and adjust before running `docker compose up -d`.

# Public image published to GitHub Container Registry.
HEADERHORNET_IMAGE=ghcr.io/emmolab/headerhornet:latest

# Host/IP binding for local deployment. Use 127.0.0.1 for local-only or 0.0.0.0 for LAN/public reverse-proxy access.
HEADERHORNET_HOST=127.0.0.1
HEADERHORNET_HOST_PORT=8080

# Container listen port. Usually leave this as 8080.
HEADERHORNET_CONTAINER_PORT=8080

# Compose project/container naming.
COMPOSE_PROJECT_NAME=headerhornet
HEADERHORNET_CONTAINER_NAME=headerhornet

# Set to 1 only for local development. Keep disabled in production.
HEADERHORNET_DEBUG=0

# Optional API key for POST /api/v1/analyze.
# Leave empty to allow unauthenticated API requests, or set a long random value in production.
# Clients can send this with either X-API-Key or Authorization Bearer header.
HEADERHORNET_API_KEY=

# Temporary API request diagnostics for integration debugging.
# HEADERHORNET_LOG_API_REQUESTS=1 logs method/path/query/content metadata, redacted request headers,
# body lengths, line counts, and SHA-256 digests.
# HEADERHORNET_LOG_API_REQUEST_BODY=1 also logs the full raw request body and normalized headers.
# Only enable body logging briefly because email headers can contain personal data.
HEADERHORNET_LOG_API_REQUESTS=0
HEADERHORNET_LOG_API_REQUEST_BODY=0
